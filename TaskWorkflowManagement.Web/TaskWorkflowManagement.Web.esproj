<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="Restore" />

  <Target Name="Build">
    <Exec Command="npm install" Condition="!Exists('node_modules')" />
    <Exec Command="npm run build" />
  </Target>

  <Target Name="Clean">
    <RemoveDir Directories="dist" />
  </Target>
</Project>
